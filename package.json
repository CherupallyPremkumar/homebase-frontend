{
  "name": "homebase-frontend",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:storefront": "playwright test --project=storefront",
    "e2e:seller": "playwright test --project=seller",
    "e2e:backoffice": "playwright test --project=backoffice",
    "e2e:platform": "playwright test --project=platform",
    "e2e:audit": "playwright test --project=audit"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
