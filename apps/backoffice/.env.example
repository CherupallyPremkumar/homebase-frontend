# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=

# Full URL of this app (required in production for NextAuth redirects)
NEXTAUTH_URL=https://backoffice.homebase.com

# ─── Keycloak ─────────────────────────────────────────────────────────────────
KEYCLOAK_CLIENT_ID=backoffice-web
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ISSUER=https://auth.homebase.com/realms/homebase

# ─── Backend ──────────────────────────────────────────────────────────────────
BACKEND_URL=https://api.homebase.com
TENANT_ID=homebase
